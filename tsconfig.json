{
  // Application `include` / `exclude` stay in tsconfig.app.json so `src` is not part of two
  // programs at once (required for `tsc -b` + project references).
  "files": [],
  "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@features/*": ["./src/features/*"],
      "@pages/*": ["./src/pages/*"],
      "@ui/*": ["./src/ui/*"],
      "@layout/*": ["./src/layout/*"],
      "@lib/*": ["./src/lib/*"],
      "@assets/*": ["./src/assets/*"]
    }
  }
}
